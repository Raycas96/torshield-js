{
	"name": "@torshield/nestjs",
	"version": "1.0.0",
	"private": true,
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@torshield/core": "workspace:*"
	},
	"peerDependencies": {
		"@nestjs/common": ">=10.0.0",
		"@nestjs/core": ">=10.0.0"
	},
	"scripts": {
		"build": "tsup && pnpm run build:types",
		"build:types": "tsc -p tsconfig.types.json",
		"test": "vitest run --passWithNoTests",
		"lint": "eslint .",
		"clean": "rimraf dist"
	},
	"devDependencies": {
		"tsup": "^8.5.1"
	}
}
