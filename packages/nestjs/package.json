{
	"name": "@torshield/nestjs",
	"version": "1.0.0",
	"private": true,
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@torshield/core": "workspace:*"
	},
	"peerDependencies": {
		"@nestjs/common": ">=10.0.0",
		"@nestjs/core": ">=10.0.0"
	},
	"scripts": {
		"build": "tsdown && pnpm run build:types",
		"build:types": "tsc -p tsconfig.types.json",
		"test": "vitest run --config vitest.config.ts",
		"lint": "eslint .",
		"clean": "rimraf dist"
	},
	"devDependencies": {
		"@nestjs/common": "^11.1.7",
		"@nestjs/core": "^11.1.7",
		"@nestjs/testing": "^11.1.7",
		"vitest": "4.1.5",
		"tsdown": "^0.21.10"
	}
}
