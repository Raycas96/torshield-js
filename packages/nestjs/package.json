{
	"name": "@raycas/torshield-nestjs",
	"version": "1.0.0",
	"private": true,
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@raycas/torshield-core": "workspace:*"
	},
	"peerDependencies": {
		"@nestjs/common": ">=10.4.22",
		"@nestjs/core": ">=10.4.22"
	},
	"scripts": {
		"build": "tsdown && pnpm run build:types",
		"build:types": "tsc -p tsconfig.types.json",
		"test": "vitest run --config vitest.config.ts",
		"lint": "eslint .",
		"clean": "rimraf dist"
	},
	"devDependencies": {
		"@nestjs/common": "^11.1.21",
		"@nestjs/core": "^11.1.21",
		"@nestjs/testing": "^11.1.21",
		"vitest": "4.1.6",
		"tsdown": "^0.22.0"
	}
}
