{
	"name": "@raycas/torshield-express",
	"version": "1.0.0",
	"private": true,
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@raycas/torshield-core": "workspace:*"
	},
	"devDependencies": {
		"@types/express": "^5.0.6",
		"@types/supertest": "^7.2.0",
		"express": "^5.2.1",
		"supertest": "^7.2.2",
		"tsdown": "^0.22.0",
		"vitest": "4.1.6"
	},
	"peerDependencies": {
		"express": ">=4.22.2"
	},
	"scripts": {
		"build": "tsdown && pnpm run build:types",
		"build:types": "tsc -p tsconfig.types.json",
		"test": "vitest run --config vitest.config.ts",
		"lint": "eslint .",
		"clean": "rimraf dist"
	}
}
