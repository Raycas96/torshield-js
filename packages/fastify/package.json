{
	"name": "@raycas/torshield-fastify",
	"version": "1.0.0",
	"private": true,
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@raycas/torshield-core": "workspace:*"
	},
	"peerDependencies": {
		"fastify": ">=5.0.0",
		"fastify-plugin": ">=5.0.0"
	},
	"scripts": {
		"build": "tsdown && pnpm run build:types",
		"build:types": "tsc -p tsconfig.types.json",
		"test": "vitest run --config vitest.config.ts",
		"lint": "eslint .",
		"clean": "rimraf dist"
	},
	"devDependencies": {
		"fastify": "5.8.5",
		"fastify-plugin": "^5.1.0",
		"vitest": "4.1.5",
		"tsdown": "^0.21.10"
	}
}
